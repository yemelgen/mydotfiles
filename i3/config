# i3 config file (v4)
#
# Please see http://i3wm.org/docs/userguide.html for a complete reference!

# SETTINGS {{{

# Modifier
set $mod Mod1

# Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod

# window settings
new_window normal
new_float normal

workspace_layout tabbed
mouse_warping none
force_focus_wrapping yes

# Font for window titles. Will also be used by the bar unless a different font
# is used in the bar {} block below.
font pango:Terminus 12

# This font is widely installed, provides lots of unicode glyphs, right-to-left
# text rendering and scalability on retina/hidpi displays (thanks to pango).
#font pango:DejaVu Sans Mono 8

# Before i3 v4.8, we used to recommend this one as the default:
# font -misc-fixed-medium-r-normal--13-120-75-75-C-70-iso10646-1
# The font above is very space-efficient, that is, it looks good, sharp and
# clear in small sizes. However, its unicode glyph coverage is limited, the old
# X core fonts rendering does not support right-to-left and this being a bitmap
# font, it doesn’t scale on retina/hidpi displays.

workspace 1 output LVDS-1
workspace 2 output DP-1
workspace 3 output VGA-1

# }}}

# ACTIONS {{{ 

# change focus
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# move focused window
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# switch to workspace
bindsym $mod+F1 workspace 1
bindsym $mod+F2 workspace 2
bindsym $mod+F3 workspace 3
bindsym $mod+F4 workspace 4
bindsym $mod+F5 workspace 5
bindsym $mod+F6 workspace 6
bindsym $mod+F7 workspace 7
bindsym $mod+F8 workspace 8

# move focused container to workspace
bindsym $mod+Shift+F1 move container to workspace 1
bindsym $mod+Shift+F2 move container to workspace 2
bindsym $mod+Shift+F3 move container to workspace 3
bindsym $mod+Shift+F4 move container to workspace 4
bindsym $mod+Shift+F5 move container to workspace 5
bindsym $mod+Shift+F6 move container to workspace 6
bindsym $mod+Shift+F7 move container to workspace 7
bindsym $mod+Shift+F8 move container to workspace 8

# change focus
bindsym $mod+Tab focus right
bindsym $mod+Shift+Tab focus left
bindsym $mod+Escape [class="URxvt" title="tty1"] focus

# change focus between tiling / floating windows
bindsym $mod+Control+Tab focus mode_toggle

# toggle tiling / floating
bindsym $mod+Control+g floating toggle

# enter fullscreen mode for the focused container
bindsym $mod+Control+f fullscreen toggle

# change container layout (stacked, tabbed, toggle split)
bindsym $mod+Control+w layout tabbed
bindsym $mod+Control+e layout toggle split
#bindsym $mod+Control+t layout stacking

# focus the parent / child container
bindsym $mod+Control+a focus parent
bindsym $mod+Control+d focus child

# split in horizontal / vertical orientation
bindsym $mod+Control+v split h
bindsym $mod+Control+s split v

# resize
bindsym $mod+Control+comma resize shrink width 10 px or 10 ppt
bindsym $mod+Control+period resize grow width 10 px or 10 ppt
bindsym $mod+Control+minus resize shrink height 10 px or 10 ppt
bindsym $mod+Control+equal resize grow height 10 px or 10 ppt

# floating mode
bindsym $mod+Control+Escape mode "$popup"

# launcher  mode
#bindsym $mod+Control+r mode "$launcher"

# kill focused window
bindsym $mod+Control+q kill

# mouse buttons
bindsym button2 kill
bindsym button8 floating toggle
bindsym button9 floating toggle

# }}}

# FUNCTIONS {{{

# start dmenu (a program launcher)
bindsym $mod+Control+Return exec dmenu_run -fn terminus -sb '#cc9933' -sf '#111111'

# start a new terminal
#bindsym $mod+Control+Return exec x-terminal-emulator 

# reload the configuration file
bindsym $mod+Control+c reload

# restart i3 inplace (preserves your layout/session, can be used to upgrade i3)
bindsym $mod++Control+r restart

# lock 
bindsym XF86ScreenSaver exec --no-startup-id xset dpms force suspend && i3lock -c 111111

# logout (logs you out of your X session)
bindsym $mod+XF86ScreenSaver exec "i3-nagbar -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -b 'Yes, exit i3' 'i3-msg exit'"

# recording / streaming
#bindsym $mod+F11 exec --no-startup-id record.sh

# suspend
#bindsym XF86Sleep exec --no-startup-id i3lock -c 111111 && systemctl suspend

# hibernate
#bindsym $mod+XF86Sleep exec --no-startup-id i3lock -c 111111 && systemctl hibernate

# screenshoting
bindsym Print exec scrot -u $HOME/media/pictures/`date +%Y-%m-%d_%H-%M-%S`.png
bindsym Control+Print exec scrot -s $HOME/media/pictures/`date +%Y-%m-%d_%H-%M-%S`.png
bindsym Shift+Print exec scrot -m $HOME/media/pictures/`date +%Y-%m-%d_%H-%M-%S`.png

# kill
bindsym --release $mod+Control+x exec --no-startup-id xkill

# yetty simulation
#bindsym $mod+v layout splitv; exec xterm; focus child; split v; layout tabbed
#bindsym $mod+v layout splitv; exec xterm; split v; layout tabbed

# }}}

# MODES {{{

# popup mode
mode "$popup" {
    # vi-like contols
    bindsym q kill, [class="URxvt" title="TERMINAL"] focus, mode "default"
    bindsym --release g exec --no-startup-id xdotool key Home
    bindsym --release Shift+g exec --no-startup-id xdotool key End

    # return back
    bindsym Escape mode "default"
    bindsym $mod+Escape [class="URxvt" title="TERMINAL"] focus, mode "default"
    bindsym $mod+Tab focus right, mode "default"
    bindsym $mod+Shift+Tab focus left, mode "default"
}

mode "$launcher" {
    bindsym f exec iceweasel
    bindsym c exec google-chrome
    bindsym i exec x-terminal-emulator -title CHAT -e tmux new-session zsh -c irssi
    bindsym k exec inkscape
    bindsym g exec gimp

    bindsym $mod+Escape [class="URxvt" title="TERMINAL"] focus, mode "default"
    bindsym $mod+Tab focus right, mode "default"
    bindsym $mod+Shift+Tab focus left, mode "default"
    bindsym Escape mode "default"
    bindsym Return mode "default"
}

# }}}

# STATUS {{{

# Start i3bar to display a workspace bar (plus the system information i3status
# finds out, if available
bar {
    colors {
        background #111111
        statusline #cc9933
        separator #777777

        focused_workspace  #111111 #cc9933 #111111
        active_workspace   #111111 #996633 #111111
        inactive_workspace #111111 #111111 #cc9933
        urgent_workspace   #2f343a #900000 #ffffff
    }
    position top
    status_command i3status
    tray_output primary
}

# }}}

# COLORS {{{

# class                 border  backgr. text    indicator
client.focused          #cc9933 #cc9933 #111111 #2e9ef4
client.focused_inactive #996633 #996633 #111111 #484e50
client.unfocused        #333333 #111111 #cc9933 #292d2e
client.urgent           #2f343a #900000 #ffffff #900000
client.placeholder      #000000 #0c0c0c #ffffff #000000
client.background       #111111

# }}}

