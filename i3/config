# STARTUP {{{

exec sexkbmap -layout us
exec xrdb -merge ~/.etc/x11/Xresources
exec xmodmap ~/.etc/x11/Xmodmap
exec fcitx
exec bash -c 'rxvt-unicode -title tty1 -e tmux new-session -s 1; i3-msg exit'

# }}}

