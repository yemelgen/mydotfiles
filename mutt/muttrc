# Settings
set sort_aux = reverse-date-received # Show newer first
set sort_browser = reverse-date
set sort = threads # Read bottom-up
unset markers # Dont add a '+' to urls that wrap
set help = no # Don't show help bar
set postpone = no # Don't create postpones
set mask=".*"  # Accept '.' in folder names
set move = no # Don't move read mail to All Mail
set delete # Don't ask to confirm deletions
unset confirmappend  # Don't ask, just do!
set quit # Don't ask to, just do!!
set sleep_time = 0 # Don't wait to switch mailboxes
set folder = ~/mail # Default folder
set strict_threads = yes
unset collapse_unread
set rfc2047_parameters = yes
set forward_format = "Fwd: %s" # format of subject when forwarding
set mime_forward = yes
set pager_stop = yes # don't go to next message automatically
set tilde = yes
set menu_scroll = yes
set pager_index_lines=15
set pager_context = 3

auto_view text/plain
auto_view text/html
alternative_order text/plain text/enriched text/html

# Format
set status_format = "%r  %f %V %> [Msgs:%?M?%M/?%m%?n? New:%n?%?o? Old:%o?%?d? Del:%d?%?F? Flag:%F?%?t? Tag:%t?%?p? Post:%p?%?b? Inc:%b?%?l? %l?] (%s/%S) (%P)"
set pager_format = "%Z %-20.20n %-30.30s%* %C/%m (%P)"
set index_format="%4C %Z %{%b %d} %-18.18n %s %?M?(%M)%?"

# Keybinds
bind index - collapse-thread
bind index _ collapse-all
bind index,attach G last-entry
bind index,attach gg first-entry
bind index,pager,attach r group-reply
#bind index,pager,attach R reply
bind pager j next-line
bind pager k previous-line
bind pager G bottom
bind pager gg top

# Aliases
set alias_file = ~/.etc/mutt/aliases
source ~/.etc/mutt/aliases
#set query_command="cat ~/.etc/mutt/aliases | grep '%s' | awk -F '[<>]' '{print $2}'"

# Mailcap
set mailcap_path = ~/.etc//mutt/mailcap

# Colors
source ~/.etc/mutt/colors

# Folder hooks
#folder-hook 'gmail' 'source ~/.etc/mutt/gmail'
folder-hook . 'push <ESC>V'

# Default account
source ~/.etc/mutt/default/local.muttrc
#source ~/.etc/mutt/default/gmail.muttrc

