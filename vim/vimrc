" My vim configuration

" SETTINGS {{{

" Make vim behave in a more useful way.
set nocompatible

" Load a color scheme.
set background=dark
colorscheme zendark

" Enable the syntax highlighting.
syntax on

" Enable the FileType autocommand event triggering.
filetype indent plugin on

" Change the terminal's title.
set title
set titleold=Terminal

" Disable beeping
set visualbell noerrorbells

" Disable shell commands in the .vimrc and .exrc files
set secure

" Lookup directories for gs, :find and other commands.
set path=**

" Print the line number in front of each line.
set number

" Show the line and column of the cursor position, separeted by a comma.
set ruler

" Hide buffers instead of closing them.
set hidden

" Show command in the last line of the screen.
set showcmd

" Show matching parenthesis.
set showmatch

" Copy indent from current line when starting a new line.
"set autoindent

" Copy the structer of the existing lines indent when autoindenting a new line.
set copyindent

" Preserve as much indent structre as possible
set preserveindent

" Do smart autoindenting when starting a new line
"set smartindent

" Insert spaces instead of tab 
set expandtab

" Number of spaces to use for each step " of (auto)indent.
set shiftwidth=4

" Number of spaces that a <Tab> counts for while performing editing operations,
" like inserting a <Tab> or using <BS>.
set softtabstop=0

" Round indent to multiple of 'shiftwidth'
set shiftround

" Number of spaces that a <Tab> in the file counts for.the tab
set tabstop=4

" Insert blanks accorind to 'shiftwidth', 'tabstop'
" or 'softtabstop' is used in other places.
set smarttab

" Enable 'list' mode. Show tabs, spaces and trailing blanks.
set list

" Strings to use in 'list' mode and for :list command.
set listchars=tab:>-,extends:>,precedes:<,trail:.,nbsp:.,space:.

" Maximum amount of memory (in Kbyte) to use for pattern matching.
set maxmempattern=2000

" Maximum number of entries that may be stored in the history.
set history=1100

" Maximun number of changes that can be undone
set undolevels=1000

" Ignore case in the patterns while searching
set ignorecase

" Override the 'ignorecase' if the search pattern contains
set smartcase

" Adjust the case of the match depending on the typed text uppercase characters.
set infercase

" Highlight matched string while typing a search command.
set incsearch

" Highlight all the matches.
set hlsearch

" Disable making a backup before overwriting a file.
set nobackup

" Disable using a swapfile for the buffer.
set noswapfile

" Set the character encoding used inside Vim.
set encoding=utf-8

" Encoding used for the terminal.
set termencoding=utf-8

" Set the character encoding for the file of this buffer
set fileencoding=utf-8

" Set a list of encodings considered when starting to edit an existing file.
set fileencodings=utf-8,utf-16le,utf-16be,cp1251

" Set the file format for the file of this buffer.
set fileformat=unix

" Set a list of file formats cosidered when starting to edit an existing file.
set fileformats=unix,dos,mac

" Specify how keyword completion works when CTRL-N or CTRL-P are used.
set complete=.,w,b,],k,s

" Specify a function to be used for Insert mode with CTRL-X CTRL-O
set omnifunc=syntaxcomplete#Complete

" Options to use for completion.
set completeopt=menuone,menu,longest,preview,noselect,noinsert

" Filenames for the tag command, separated by spaces or commas.
set tags+=TAGS

" Enable folding
set foldenable

" Use markers to specify folds.
set foldmethod=marker

" The start and end marker used when 'foldmethod' is 'marker'.
set foldmarker={{{,}}}

" Enable the use of the mouse.
set mouse=a

" Enable or disable Past mode.
set pastetoggle=<F12>

" Use the register '+' to copy/paste from/to the X11 clibboard
set clipboard=unnamed,unnamedplus

" The time in milliseconds that is waited for a key code.
" or mapped key sequence to complete.
set timeoutlen=500 ttimeoutlen=-1

" Check the number of lines for set of commands.
set modeline modelines=5

" Enhance the command-line  completion.
set wildmenu

" Ignore sort of file patterns while expanding wildcards.
set wildignore=*.swp,*.bak,*.pyc,*.class

" Start a widlcard expastion in the command-line.
set wildcharm=<Tab>

" Specify the completion mode that is used for wildmenu.
set wildmode=full

" Show the statusline.
set laststatus=2 
set statusline=%!StatusLine(winnr())

" Set spell language
set spell spelllang=en_gb

" }}}

