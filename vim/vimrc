" FUNCTIONS {{{

function! ScrollPreview( dir )
    for nr in range( 1, winnr('$') )
        if getwinvar( nr, '&previewwindow' )
            exe nr.'wincmd w'
            if a:dir == 'down'
                exe "normal! \<C-d>"
            else
                exe "normal! \<C-u>"
            endif
            wincmd p
            return
        endif
    endfor
endfunction

function! BuildBufTab( buffers )
    let output = ''

    for buf in a:buffers
        let type = getbufvar( buf, '&buftype' )
        let hidden = getbufvar( buf, '&bufhidden' )

        if type == 'nofile' || type == 'quickfix' || hidden == 'wipe'
            continue
        endif

        let name = fnamemodify( bufname(buf), ':t' )
        if name == ''
            let name = '[No Name]'
        endif

        if buf == bufnr('%')
            let output = output.buf.':'.name.'*'
        elseif buf == bufnr('#')
            let output = output.' '.buf.':'.name.'-'
        else
            let output = output.' '.buf.':'.name
        endif
    endfor

    return output
endfunction

function! BufTabLeft( nr )
    let buffers = []
    for buf in filter( range( 1, bufnr('%') - 1 ), "buflisted(v:val)")
        let buffers += [ buf ]
    endfor
    if len(buffers) > 4
        return '< '.BuildBufTab( buffers[-4:] )
    endif
    return BuildBufTab( buffers )
endfunction

function! BufTabRight( nr )
    let buffers = []
    for buf in filter( range( bufnr('%') + 1, bufnr('$') ), "buflisted(v:val)")
        let buffers += [ buf ]
    endfor
    if len(buffers) > 4
        return BuildBufTab( buffers[:3] ).' >'
    endif
    return BuildBufTab( buffers )
endfunction

function! BufTabCenter( nr )
    let buffers = [ bufnr('%') ]
    if winnr() == a:nr
        return BuildBufTab( buffers )
    else
        return ''
    endif
endfunction

function! BufTabCenterNC( nr )
    let buffers = [ bufnr('%') ]
    if winnr() == a:nr
        return ''
    else
        return BuildBufTab( buffers )
    endif
endfunction

function! StatusLine( nr )
    let left = '%{BufTabLeft('.a:nr.')} '
    let center = '%#User1#%{BufTabCenter('.a:nr.')}%#User2#%{BufTabCenterNC('.a:nr.')}%0*'
    let right = ' %{BufTabRight('.a:nr.')} '
    let buftab = left.center.right
    let expander = '%= '
    let filetype = '%{&ft} '
    let encoding = '%{&fenc?&fenc:&enc}%{&bomb?"-bom":""} '
    let charcode = '0x%B '
    let navbar = '%l,%c%V/%L %P '
    return buftab.expander.filetype.encoding.charcode.navbar
endfunction

